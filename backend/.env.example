# ─────────────────────────────────────────
# BACKEND Environment Variables
# Copy this file to backend/.env and fill in real values.
# NEVER commit the actual .env file to Git!
# ─────────────────────────────────────────

# ── Server ───────────────────────────────
NODE_ENV=development

# ── MongoDB ──────────────────────────────
# Use the /portfolio database (not Farely or other app DBs)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority&appName=TaskMaster

# ── JWT ──────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ── Admin Portal Credentials ─────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── AWS S3 (Project Images) ──────────────
# Images are stored under s3://<bucket>/projects/
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=riyan-portfolio-images

# ── Brevo (Contact Form — emails go to your inbox) ───
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# ── CORS (optional) ──────────────────────
FRONTEND_URL=http://localhost:3000
