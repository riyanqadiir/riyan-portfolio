# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND Environment Variables
# Copy to frontend/.env for local overrides (optional).
#
# In development, /api/* is proxied to the backend via src/setupProxy.js.
# In production on Vercel, API routes are served from the same domain.
# ─────────────────────────────────────────────────────────────────────────────

# Override backend URL for local dev (default: http://localhost:3001)
# REACT_APP_API_URL=http://localhost:3001
